{
  "version": "2.1.0",
  "scan": {
    "root_path": "C:\\",
    "max_depth": 5,
    "safe_extensions": [
      ".tmp", ".temp", ".log", ".bak", ".old", ".backup",
      ".cache", ".dmp", ".crash", ".etl", ".evtx"
    ],
    "large_file_threshold_mb": 100,
    "old_file_days": 30,
    "exclude_paths": [
      "C:\\Windows\\System32",
      "C:\\Windows\\SysWOW64",
      "C:\\Windows\\Boot",
      "C:\\Windows\\Fonts",
      "C:\\Windows\\WinSxS",
      "C:\\Program Files",
      "C:\\Program Files (x86)",
      "C:\\$Recycle.Bin",
      "C:\\System Volume Information",
      "C:\\Recovery"
    ]
  },
  "clean": {
    "use_trash": true,
    "backup_before_delete": false,
    "confirm_before_delete": true,
    "skip_system_files": true,
    "skip_desktop_files": true
  },
  "monitor": {
    "interval": 60,
    "alert_threshold": 90,
    "critical_threshold": 95,
    "rapid_growth_mb_per_hour": 100
  },
  "recommendation": {
    "enabled": true,
    "frequency": "weekly",
    "auto_cleanup": false
  },
  "ui": {
    "theme": "light",
    "language": "zh-CN",
    "window_width": 1200,
    "window_height": 800,
    "auto_refresh": true,
    "refresh_interval": 5000
  },
  "backup": {
    "backup_root": "",
    "verify_after_backup": true,
    "max_backups": 10
  },
  "logging": {
    "level": "INFO",
    "file": "~\\CleanBot\\logs\\cleanbot.log",
    "max_size_mb": 10,
    "backup_count": 5
  }
}
